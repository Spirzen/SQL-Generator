<Window x:Class="SQL_Generator.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SQL Generator"
        Height="720" Width="1024"
        MinHeight="560" MinWidth="880"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="380" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,16">
            <TextBlock Text="SQL Generator" FontSize="22" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Конструктор запросов SELECT, INSERT, UPDATE, DELETE"
                       FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
        </StackPanel>

        <!-- Form -->
        <Border Grid.Row="1" Grid.Column="0" Background="White" CornerRadius="10"
                BorderBrush="{StaticResource BorderBrushAccent}" BorderThickness="1" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Параметры" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                    <TextBlock Style="{StaticResource SectionLabel}" Text="Основное" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="Тип запроса" />
                        <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource StyledComboBox}"
                                  ItemsSource="{Binding QueryTypes}" SelectedItem="{Binding SelectedQueryType}" />

                        <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="Таблица" />
                        <TextBox Grid.Row="2" Grid.Column="1" Style="{StaticResource StyledTextBox}"
                                 Tag="users" Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="4" Style="{StaticResource FieldLabel}" Text="Столбцы" />
                        <TextBox Grid.Row="4" Grid.Column="1" Style="{StaticResource StyledTextBox}"
                                 Tag="id, name, email"
                                 Text="{Binding ColumnsString, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="6" Style="{StaticResource FieldLabel}" Text="Значения" />
                        <TextBox Grid.Row="6" Grid.Column="1" Style="{StaticResource StyledTextBox}"
                                 Tag="1, 'John', 'john@mail.com'"
                                 Text="{Binding ValuesString, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsValuesEnabled}" />
                    </Grid>

                    <TextBlock Style="{StaticResource SectionLabel}" Text="Фильтр (WHERE)" />
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Style="{StaticResource StyledComboBox}"
                                  ItemsSource="{Binding Columns}" SelectedItem="{Binding SelectedFilterColumn}" />
                        <ComboBox Grid.Column="2" Style="{StaticResource StyledComboBox}"
                                  ItemsSource="{Binding Operators}" SelectedItem="{Binding SelectedOperator}" />
                        <TextBox Grid.Column="4" Style="{StaticResource StyledTextBox}" Tag="значение"
                                 Text="{Binding FilterValue, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsFilterValueEnabled}" />
                    </Grid>

                    <StackPanel Visibility="{Binding IsSelectOptionsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Style="{StaticResource SectionLabel}" Text="JOIN" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource FieldLabel}" Text="Тип" />
                            <ComboBox Grid.Row="0" Grid.Column="1" Style="{StaticResource StyledComboBox}"
                                      ItemsSource="{Binding JoinTypes}" SelectedItem="{Binding SelectedJoinType}" />
                            <TextBlock Grid.Row="2" Style="{StaticResource FieldLabel}" Text="Таблица / столбец" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <TextBox Style="{StaticResource StyledTextBox}" Tag="orders" Width="120"
                                         Text="{Binding JoinTable, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" />
                                <TextBox Style="{StaticResource StyledTextBox}" Tag="user_id" Width="120"
                                         Text="{Binding JoinColumn, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <TextBlock Grid.Row="4" Style="{StaticResource FieldLabel}" Text="Связь с" />
                            <ComboBox Grid.Row="4" Grid.Column="1" Style="{StaticResource StyledComboBox}"
                                      ItemsSource="{Binding Columns}" SelectedItem="{Binding JoinMainTableColumn}" />
                        </Grid>

                        <TextBlock Style="{StaticResource SectionLabel}" Text="Сортировка и лимит" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Style="{StaticResource StyledComboBox}"
                                      ItemsSource="{Binding Columns}" SelectedItem="{Binding SelectedOrderByColumn}" />
                            <ComboBox Grid.Column="2" Style="{StaticResource StyledComboBox}"
                                      ItemsSource="{Binding OrderDirections}" SelectedItem="{Binding SelectedOrderDirection}" />
                            <TextBox Grid.Column="4" Style="{StaticResource StyledTextBox}" Tag="10"
                                     Text="{Binding LimitText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>

                        <CheckBox Content="SELECT DISTINCT" IsChecked="{Binding IsDistinct}"
                                  Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Сгенерировать" Style="{StaticResource StyledButton}"
                                Command="{Binding GenerateQueryCommand}" Margin="0,0,8,0" />
                        <Button Content="Очистить" Style="{StaticResource SecondaryButton}"
                                Command="{Binding ClearFormCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Output -->
        <Border Grid.Row="1" Grid.Column="2" CornerRadius="10"
                Background="{StaticResource CodeBackgroundBrush}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="14,12" BorderBrush="#313244" BorderThickness="0,0,0,1">
                    <TextBlock Text="Результат" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource CodeForegroundBrush}" />
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto" Padding="14">
                    <TextBox Text="{Binding GeneratedQuery, Mode=OneWay}"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="14" Foreground="{StaticResource CodeForegroundBrush}"
                             Background="Transparent" BorderThickness="0"
                             TextWrapping="Wrap" IsReadOnly="True" AcceptsReturn="True" />
                </ScrollViewer>

                <Border Grid.Row="2" Padding="14,12" BorderBrush="#313244" BorderThickness="0,1,0,0">
                    <Button Content="Скопировать в буфер" Style="{StaticResource StyledButton}"
                            Command="{Binding CopyToClipboardCommand}"
                            IsEnabled="{Binding GeneratedQuery, Converter={StaticResource StringIsNotNullOrEmptyConverter}}"
                            HorizontalAlignment="Stretch" />
                </Border>
            </Grid>
        </Border>

        <!-- Status -->
        <Border Grid.Row="2" Grid.ColumnSpan="3" Margin="0,12,0,0" Padding="10,8"
                Background="White" CornerRadius="6"
                BorderBrush="{StaticResource BorderBrushAccent}" BorderThickness="1">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                       Foreground="{StaticResource MutedTextBrush}" />
        </Border>
    </Grid>
</Window>
